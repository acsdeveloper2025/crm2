{
  "name": "@crm2/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "openapi": "tsx src/platform/openapi/cli.ts"
  },
  "dependencies": {
    "@crm2/access": "workspace:*",
    "@crm2/config": "workspace:*",
    "@crm2/logger": "workspace:*",
    "@crm2/sdk": "workspace:*",
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.34.0",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.0",
    "firebase-admin": "^14.0.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.12.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@crm2/test-utils": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

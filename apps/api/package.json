{
  "name": "@crm2/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:contract-mobile": "vitest run --coverage.enabled=false src/modules/verification-tasks src/modules/location src/modules/users src/modules/notifications src/modules/sync src/modules/auth src/modules/consents src/modules/reference",
    "openapi": "tsx src/platform/openapi/cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/client-sesv2": "^3.1070.0",
    "@aws-sdk/client-socialmessaging": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@crm2/access": "workspace:*",
    "@crm2/config": "workspace:*",
    "@crm2/logger": "workspace:*",
    "@crm2/sdk": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.78.1",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.0.0",
    "handlebars": "^4.7.9",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@crm2/test-utils": "workspace:*",
    "@types/archiver": "^6.0.3",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

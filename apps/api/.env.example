# Example env for @crm2/api — copy to `.env` (gitignored) and fill real values for local dev.
# `pnpm dev` loads `.env` via `tsx --env-file-if-exists=.env`. Tests pass DATABASE_URL inline.
NODE_ENV=development
PORT=4000
# Persistent dev DB (the ephemeral :5433 test DB is set inline by the test harness).
DATABASE_URL=postgresql://postgres@127.0.0.1:54329/crm2_dev
# Object storage (ADR-0021) — local MinIO via docker compose.
STORAGE_BACKEND=minio
S3_BUCKET=crm2-dev
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Reverse-geocode (ADR-0026, Field Monitoring). Server-side ONLY; restrict the key to the
# Geocoding API + the server IP. Optional — without it the UI shows raw coordinates, not an error.
GOOGLE_GEOCODING_API_KEY=__set_your_google_geocoding_key__
# FCM push (ADR-0027 phase 2). Path (relative to the api cwd) to the Firebase service-account JSON —
# MUST be the same project as the device's google-services.json (`caseflow-mobile`). Drop the file
# under secrets/ (gitignored); never commit it. Optional — without it push is a disabled no-op.
FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json
# Background jobs (ADR-0030) + socket.io fan-out. Optional: unset → jobs run IN-PROCESS (frictionless
# dev/tests, no Valkey). Set BOTH to run the out-of-process tier — `docker compose up valkey` (host
# 6380; v1's crm_redis owns 6379) AND a `ROLE=worker` process (ROLE=worker pnpm --filter @crm2/api dev).
# REDIS_QUEUE_URL = BullMQ queue; REDIS_CACHE_URL = socket.io adapter (so the worker can push to clients).
# REDIS_QUEUE_URL=redis://127.0.0.1:6380
# REDIS_CACHE_URL=redis://127.0.0.1:6380
# Hard ceiling on one background EXPORT job's rows (default 200000 covers the ~157k pincode catalog;
# above it the export is flagged `capped`, never silently truncated). Raise only with streaming builders.
# EXPORT_JOB_MAX_ROWS=200000

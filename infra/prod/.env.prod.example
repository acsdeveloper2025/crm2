# =============================================================================
# CRM2 production env — TEMPLATE ONLY (keys, no real values). The real file lives
# on the box at /opt/crm2/secrets/.env.prod (mode 600) and is NEVER committed.
# Generate strong secrets on the box, e.g.:
#   PG=$(openssl rand -hex 24); JWT=$(openssl rand -base64 48 | tr -d '\n')
#   MFA=$(openssl rand -base64 32 | tr -d '\n')   # 32 bytes → AES-256-GCM
# Do NOT use demo credentials (no postgres/postgres, no minioadmin).
# =============================================================================
NODE_ENV=production
ROLE=api
PORT=4000

# --- Postgres (compose service: db) ---
POSTGRES_USER=crm2
POSTGRES_PASSWORD=__generate_openssl_rand_hex_24__
POSTGRES_DB=crm2_prod
DATABASE_URL=postgresql://crm2:__same_password__@db:5432/crm2_prod

# --- Auth ---
JWT_SECRET=__generate_openssl_rand_base64_48__
MFA_ENC_KEY=__generate_openssl_rand_base64_32__

# --- Object storage (compose service: minio) ---
# STORAGE_BACKEND must be minio|s3 (there is NO working 'local' provider).
# S3_ENDPOINT is the PUBLIC host so presigned URLs reach the browser; nginx
# proxies /crm2-prod/ → minio:9000 preserving Host so the signature validates.
STORAGE_BACKEND=minio
S3_BUCKET=crm2-prod
S3_REGION=ap-south-1
S3_ENDPOINT=https://crm.allcheckservices.com
S3_ACCESS_KEY_ID=__generate_openssl_rand_hex_12__
S3_SECRET_ACCESS_KEY=__generate_openssl_rand_hex_32__

# --- Mail (optional; inert unless SMTP_HOST set) ---
MAIL_FROM=CRM2 <no-reply@crm2.local>

# --- Reverse geocoding (optional; server-side Google key, IP-restricted) ---
GOOGLE_GEOCODING_API_KEY=__optional__

# --- FCM push (optional; file mounted as a docker secret) ---
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account

# --- FUTURE out-of-process job tier (leave UNSET → jobs run in the api) ---
# VALKEY_PASSWORD=__generate__
# REDIS_QUEUE_URL=redis://:__pw__@valkey:6379
# REDIS_CACHE_URL=redis://:__pw__@valkey:6379

# ===== Dependencies =====
node_modules/
.pnpm-store/
.pnpm-debug.log*

# ===== Build outputs =====
dist/
build/
out/
*.tsbuildinfo

# ===== Turbo / Vite caches =====
.turbo/
.vite/
vite.config.*.timestamp-*

# ===== Tests & coverage =====
coverage/
*.lcov
.nyc_output/
# Playwright (E2E)
playwright-report/
test-results/
.playwright/
blob-report/
**/e2e/.auth/

# ===== Env & secrets (NEVER commit) =====
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p8
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
# Cloud / service-account credentials (Firebase Admin SDK · GCP · GitHub Actions).
# The app loads these from secrets/ (gitignored); the patterns below are defense-in-depth
# in case a credentials file is ever dropped elsewhere in the tree.
*serviceAccount*.json
*-firebase-adminsdk-*.json
*google-credentials*.json
*gcp-*key*.json
gha-creds-*.json
admin-credentials*.txt

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ===== Claude Code session state (worktrees, launch.json, settings) =====
.claude/

# ===== Editor / IDE =====
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ===== OS =====
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== Misc =====
*.local
.cache/
tmp/
.temp/

# Local-only session/working scratch prompts (not tracked)
docs/prompts/

# subagent-driven-development scratch
.superpowers/
